# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง (อย่า commit .env)

# LLM (chat) — gateway 9arm, key เดียวกับฝั่ง Next.js
LLM_API_KEY=
LLM_BASE_URL=https://gateway.9arm.co/v1
LLM_MODEL=qwen3.6-35b-a3b

# Embedding — สมัครฟรีที่ https://jina.ai/embeddings
JINA_API_KEY=
JINA_MODEL=jina-embeddings-v3
EMBED_DIM=1024

# Supabase (Project Settings > API)
SUPABASE_URL=
SUPABASE_KEY=

# CORS — domain ของ Next.js (คั่นด้วย comma)
ALLOWED_ORIGINS=http://localhost:3000
